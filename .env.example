DICT_PATH=server/data/dict.txt
PORT=3001
NODE_ENV=development
GRID_TTL_MS=600000
# Set to 1 (or more) only when behind a trusted reverse proxy (nginx, caddy…).
# Off = req.ip is the direct socket address, immune to X-Forwarded-For spoofing.
TRUST_PROXY=0
# Comma-separated allowed origins. "*" or empty = allow all (dev only).
CORS_ORIGIN=*
