DICT_PATH=server/data/dict.txt
PORT=3001
NODE_ENV=development
GRID_TTL_MS=600000
# Set to 1 (or more) only when behind a trusted reverse proxy (nginx, caddy…).
# Off = req.ip is the direct socket address, immune to X-Forwarded-For spoofing.
TRUST_PROXY=0
# Comma-separated allowed origins. "*" or empty = allow all (dev only).
CORS_ORIGIN=*

# --- Cloudflare Workers deployment ---
# These vars only apply to the Node/Express server above. On Cloudflare the
# Worker config lives in wrangler.jsonc: the dictionary is read from the R2
# DICTIONARY bucket (not DICT_PATH), scores persist in D1, and game/room state
# lives in Durable Objects. CORS_ORIGIN can be set as a Worker var (Settings →
# Variables) if the client is served from a different origin than the Worker;
# a same-origin deploy (Worker serves client/dist) needs no CORS config.
